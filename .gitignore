# Go Workspaces
go.work
go.work.sum

# --- TRINITY EMPIRE ADDITIONS ---

# Cloudflare Workers (Infrastructure Security)
.wrangler/
.dev.vars
.mf/
dist/
build/

# OS Metadata (System Hygiene)
.DS_Store
Thumbs.db
ehthumbs.db

# Editor/IDE Configs (Keep your environment private)
.vscode/
.idea/
.project
.classpath
.settings/

# Secret & Environment Files (Zero-Trust)
.env
.env.*
*.secret
*.key
*.pem
secrets/

